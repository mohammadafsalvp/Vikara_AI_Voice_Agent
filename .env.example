# Google Cloud Settings
# 1. Enable Google Calendar API in Google Cloud Console
# 2. Create a Service Account, download JSON key, and share your calendar with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project-id.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Vapi Intelligence Settings (https://dashboard.vapi.ai)
VAPI_PUBLIC_KEY=your-vapi-public-key
VAPI_AGENT_ID=your-vapi-agent-id

# Frontend Access (Next.js Public Variables)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key
NEXT_PUBLIC_VAPI_AGENT_ID=your-vapi-agent-id
